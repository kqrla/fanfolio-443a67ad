# --- Required ---
# Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# --- Optional ---
# TMDB autocomplete for the media search input. Free key:
# https://developer.themoviedb.org/docs/getting-started
VITE_TMDB_API_KEY=
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3
VITE_TMDB_IMAGE_BASE=https://image.tmdb.org/t/p/w500

# Public canonical URL used when generating sharable profile links.
# If unset, falls back to window.location.origin at runtime.
VITE_SITE_URL=
